    }

    .btn-primary {
        background: var(--blue);
        color: var(--bg);
        font-weight: 600;
    }

    .btn-secondary {
        background: transparent;
        color: var(--fg-dim);
        border: 1px solid var(--border);
    }

    .btn-icon {
        display: block;
        flex-shrink: 0;
    }

