    section {
        padding: 4rem 0;
        border-top: 1px solid var(--border);
    }

    .section-title {
        font-size: 0.8rem;
        font-weight: 500;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--comment);
        margin-bottom: 2.5rem;
    }

    /* ── Features ─────────────────────────────────────────────────── */
    .features-inner {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    /* Marquee row */
    .marquee-grid {
